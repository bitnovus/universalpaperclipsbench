#!/usr/bin/env python3
import base64
import json
import sys
import time
import urllib.error
import urllib.request
from pathlib import Path

BASE_URL = "http://127.0.0.1:8765"
PROTOCOL_VERSION = "2024-11-05"


def daemon(path, payload=None, timeout=120):
    data = None if payload is None else json.dumps(payload).encode("utf-8")
    req = urllib.request.Request(
        f"{BASE_URL}{path}",
        data=data,
        headers={"Content-Type": "application/json"},
        method="POST" if payload is not None else "GET",
    )
    with urllib.request.urlopen(req, timeout=timeout) as response:
        body = response.read().decode("utf-8")
    return json.loads(body) if body else None


def normalize_ref(value):
    if value is None:
        return None
    ref = str(value)
    return ref[1:] if ref.startswith("e") and ref[1:].isdigit() else ref


def parse_values(value):
    if value is None:
        return []
    if isinstance(value, list):
        return value
    if isinstance(value, str):
        try:
            parsed = json.loads(value)
            return parsed if isinstance(parsed, list) else [parsed]
        except json.JSONDecodeError:
            return [value]
    return [value]


def snapshot_text(payload):
    lines = ["### Page", f"- Page URL: {payload.get('url', '')}", "### Snapshot"]
    for item in payload.get("elements", []):
        ref = f"e{item['ref']}"
        tag = item.get("tag") or "element"
        role = item.get("role") or {
            "button": "button",
            "a": "link",
            "input": "input",
            "select": "combobox",
            "textarea": "textbox",
        }.get(tag, tag)
        text = (item.get("text") or item.get("id") or role).replace('"', '\\"')
        suffix = f" [ref={ref}]"
        if item.get("id"):
            suffix += f" [id={item['id']}]"
        if item.get("disabled"):
            suffix += " [disabled]"
        lines.append(f'- {role} "{text}"{suffix}')
    return "\n".join(lines)


def text_result(text, is_error=False):
    return {"content": [{"type": "text", "text": text}], "isError": is_error}


def image_result(path):
    content = [{"type": "text", "text": f"Screenshot saved to {path}"}]
    try:
        data = base64.b64encode(Path(path).read_bytes()).decode("ascii")
        content.append({"type": "image", "data": data, "mimeType": "image/png"})
    except OSError as exc:
        content.append({"type": "text", "text": f"Could not read screenshot: {exc}"})
    return {"content": content, "isError": False}


TOOLS = [
    {
        "name": "browser_snapshot",
        "description": "Capture the current visible page as an accessibility-like snapshot with refs for actions.",
        "inputSchema": {"type": "object", "properties": {}, "additionalProperties": False},
    },
    {
        "name": "browser_take_screenshot",
        "description": "Capture a full-page PNG screenshot and return it as an image.",
        "inputSchema": {"type": "object", "properties": {}, "additionalProperties": True},
    },
    {
        "name": "browser_click",
        "description": "Click a visible enabled element by snapshot ref or visible text.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "ref": {"type": "string"},
                "target": {"type": "string"},
                "text": {"type": "string"},
                "element": {"type": "string"},
                "doubleClick": {"type": "boolean"},
            },
            "additionalProperties": False,
        },
    },
    {
        "name": "browser_type",
        "description": "Type text into a visible element by snapshot ref.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "ref": {"type": "string"},
                "target": {"type": "string"},
                "text": {"type": "string"},
                "clear": {"type": "boolean"},
                "submit": {"type": "boolean"},
            },
            "required": ["text"],
            "additionalProperties": False,
        },
    },
    {
        "name": "browser_select_option",
        "description": "Select an option in a visible dropdown by snapshot ref.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "ref": {"type": "string"},
                "target": {"type": "string"},
                "values": {},
                "value": {"type": "string"},
                "label": {"type": "string"},
                "index": {"type": "integer"},
                "element": {"type": "string"},
            },
            "additionalProperties": False,
        },
    },
    {
        "name": "browser_press_key",
        "description": "Press a keyboard key such as Enter, ArrowDown, or Tab.",
        "inputSchema": {
            "type": "object",
            "properties": {"key": {"type": "string"}},
            "required": ["key"],
            "additionalProperties": False,
        },
    },
    {
        "name": "browser_wait_for",
        "description": "Wait for game progress or for visible text to appear.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "time": {"type": "number"},
                "seconds": {"type": "number"},
                "text": {"type": "string"},
                "timeout": {"type": "number"},
            },
            "additionalProperties": False,
        },
    },
]


def call_tool(name, args):
    args = args or {}
    if name == "browser_snapshot":
        return text_result(snapshot_text(daemon("/dom", {})))
    if name == "browser_take_screenshot":
        result = daemon("/screenshot", {})
        return image_result(result["path"])
    if name == "browser_click":
        ref = normalize_ref(args.get("ref") or args.get("target"))
        text = args.get("text") or args.get("element")
        if not ref and not text:
            raise ValueError("browser_click requires ref, target, text, or element")
        payload = {"ref": ref} if ref else {"text": text}
        daemon("/click", payload)
        if args.get("doubleClick"):
            daemon("/click", payload)
        return text_result("Clicked.")
    if name == "browser_type":
        ref = normalize_ref(args.get("ref") or args.get("target"))
        if not ref:
            raise ValueError("browser_type requires ref")
        daemon("/type", {"ref": ref, "text": args.get("text", ""), "clear": bool(args.get("clear"))})
        if args.get("submit"):
            daemon("/key", {"key": "Enter"})
        return text_result("Typed.")
    if name == "browser_select_option":
        ref = normalize_ref(args.get("ref") or args.get("target"))
        if not ref:
            raise ValueError("browser_select_option requires ref")
        values = parse_values(args.get("values"))
        if args.get("label"):
            payload = {"ref": ref, "label": args["label"]}
        elif args.get("value"):
            payload = {"ref": ref, "value": args["value"]}
        elif args.get("index") is not None:
            payload = {"ref": ref, "index": args["index"]}
        elif values:
            payload = {"ref": ref, "label": str(values[0])}
        else:
            raise ValueError("browser_select_option requires values, label, value, or index")
        daemon("/select", payload)
        return text_result("Selected.")
    if name == "browser_press_key":
        daemon("/key", {"key": args["key"]})
        return text_result("Key pressed.")
    if name == "browser_wait_for":
        if args.get("text"):
            deadline = time.time() + float(args.get("timeout", 60))
            needle = str(args["text"]).lower()
            while time.time() < deadline:
                dom = daemon("/dom", {})
                if needle in json.dumps(dom).lower():
                    return text_result(f"Text appeared: {args['text']}")
                daemon("/wait", {"seconds": 1}, timeout=35)
            return text_result(f"Timed out waiting for text: {args['text']}", is_error=True)
        seconds = float(args.get("time", args.get("seconds", 1)))
        daemon("/wait", {"seconds": seconds}, timeout=max(35, int(seconds) + 30))
        return text_result(f"Waited {seconds:g} seconds.")
    raise LookupError(f"unknown tool: {name}")


def handle(message):
    method = message.get("method")
    if method == "initialize":
        return {
            "protocolVersion": PROTOCOL_VERSION,
            "capabilities": {"tools": {}},
            "serverInfo": {"name": "paperclips-browser", "version": "1.0.0"},
        }
    if method == "tools/list":
        return {"tools": TOOLS}
    if method == "tools/call":
        params = message.get("params") or {}
        try:
            return call_tool(params.get("name"), params.get("arguments") or {})
        except Exception as exc:
            return text_result(str(exc), is_error=True)
    if method and method.startswith("notifications/"):
        return None
    raise LookupError(f"unsupported method: {method}")


def respond(message, result=None, error=None):
    if "id" not in message:
        return
    payload = {"jsonrpc": "2.0", "id": message["id"]}
    if error is not None:
        payload["error"] = {"code": -32000, "message": str(error)}
    else:
        payload["result"] = result
    print(json.dumps(payload), flush=True)


def main():
    for line in sys.stdin:
        if not line.strip():
            continue
        try:
            message = json.loads(line)
            respond(message, result=handle(message))
        except Exception as exc:
            try:
                respond(message, error=exc)
            except Exception:
                print(
                    json.dumps(
                        {"jsonrpc": "2.0", "id": None, "error": {"code": -32700, "message": str(exc)}}
                    ),
                    flush=True,
                )


if __name__ == "__main__":
    main()
